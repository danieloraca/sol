{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sol",
  "version": "0.1.0",
  "identifier": "com.danieloraca.sol",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sol",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
